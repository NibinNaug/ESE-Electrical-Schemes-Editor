{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ESE",
  "version": "0.1.0-beta.2",
  "identifier": "org.ese.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ESE — Electrical Schemes Editor",
        "width": 1440,
        "height": 900,
        "minWidth": 760,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["French", "English"]
      }
    },
    "android": {
      "versionCode": 1002
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJCNUNGOUJFMDc1QzQ0RQpSV1JPeEhYZ204KzFBdnRCVjlmODk1MlZsUFRFbTdvVzFibkVEZFJFb2w0U2VCRkdySm11YjlTdAo="
    }
  }
}
